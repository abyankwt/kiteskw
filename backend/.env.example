NODE_ENV=development
PORT=3001

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kites_db
DB_USER=kites_user
DB_PASSWORD=your_password_here

# JWT
JWT_ACCESS_SECRET=change_this_to_a_64_char_random_string
JWT_REFRESH_SECRET=change_this_to_a_different_64_char_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Frontend URL (for CORS + payment redirects)
FRONTEND_URL=http://localhost:8080
API_BASE_URL=http://localhost:3001

# Hesabe Payment Gateway
HESABE_MERCHANT_CODE=
HESABE_SECRET_KEY=
HESABE_ACCESS_CODE=
HESABE_IV=
HESABE_PAYMENT_URL=https://api.hesabe.com/payment

# File Upload
UPLOAD_DIR=uploads/thumbnails
MAX_FILE_SIZE_MB=5
