NODE_ENV=development
PORT=3001

# ── Database ──────────────────────────────────────────────────────────────────
# Option A: Supabase (or any hosted PostgreSQL) — use DATABASE_URL
# Get this from: Supabase → Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres.xbmczvjrkgjdvjiaggml:mnrJg5YyMXFy2024@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres
# Option B: Local PostgreSQL — use individual vars (leave DATABASE_URL empty)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=kites_db
# DB_USER=kites_user
# DB_PASSWORD=your_password_here

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_this_to_a_64_char_random_string
JWT_REFRESH_SECRET=change_this_to_a_different_64_char_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:8080
API_BASE_URL=http://localhost:3001

# ── Hesabe Payment Gateway ────────────────────────────────────────────────────
